rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Common helper functions
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Helper to validate user profile schema
    function isValidUser(data) {
      return data.keys().hasAll(['phone', 'name', 'createdAt']) &&
             data.keys().size() >= 3 &&
             data.phone is string && data.phone.size() >= 5 && data.phone.size() <= 20 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.createdAt is string;
    }

    // Helper to validate product/order structure
    function isValidOrder(data) {
      return data.keys().hasAll(['id', 'customerPhone', 'customerName', 'customerAddress', 'paymentMethod', 'totalAmount', 'createdAt']) &&
             data.id is string &&
             data.customerPhone is string && data.customerPhone.size() >= 5 && data.customerPhone.size() <= 20 &&
             data.customerName is string && data.customerName.size() > 0 && data.customerName.size() <= 100 &&
             data.customerAddress is string && data.customerAddress.size() > 0 && data.customerAddress.size() <= 500 &&
             data.paymentMethod is string &&
             data.totalAmount is number && data.totalAmount >= 0 &&
             data.createdAt is string;
    }

    // Users Collection Rule
    match /users/{phone} {
      allow get: if true; // Any customer can query user profile exists/login matching their phone number
      allow create: if isValidUser(incoming());
      allow update: if isValidUser(incoming()) && incoming().phone == existing().phone;
      allow delete: if false; // Deletions strictly forbidden
    }

    // Orders Collection Rule
    match /orders/{orderId} {
      allow get: if true; // Any customer can retrieve order context matching their order receipt tracking id
      allow create: if isValidOrder(incoming());
      allow update: if isValidOrder(incoming()) && incoming().id == existing().id;
      allow list: if true; // For listing customer's local list of orders
      allow delete: if false; // Deletions strictly forbidden
    }
  }
}
