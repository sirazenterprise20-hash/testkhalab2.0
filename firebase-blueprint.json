{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile registered via phone number after placing their first order.",
      "type": "object",
      "properties": {
        "phone": {
          "type": "string",
          "description": "User's unique phone number which acts as their login key."
        },
        "name": {
          "type": "string",
          "description": "Display name of the user."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "User's optional email address."
        },
        "address": {
          "type": "string",
          "description": "User's default delivery address."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Profile registration timestamp."
        }
      },
      "required": ["phone", "name", "createdAt"]
    },
    "Order": {
      "title": "Customer Order",
      "description": "A purchase order placed by a customer.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique Order ID."
        },
        "customerPhone": {
          "type": "string",
          "description": "The customer's phone number."
        },
        "customerName": {
          "type": "string",
          "description": "The customer's name at purchase."
        },
        "customerAddress": {
          "type": "string",
          "description": "The delivery address."
        },
        "paymentMethod": {
          "type": "string",
          "description": "bKash, Nagad, Rocket, COD, etc."
        },
        "paymentStatus": {
          "type": "string",
          "description": "Payment status of the order."
        },
        "deliveryStatus": {
          "type": "string",
          "description": "Current dispatch progress state."
        },
        "totalAmount": {
          "type": "number",
          "description": "Total payable amount."
        },
        "discountAmount": {
          "type": "number",
          "description": "Discount applied."
        },
        "items": {
          "type": "array",
          "description": "List of clothing items purchased."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Order placement timestamp."
        }
      },
      "required": ["id", "customerPhone", "customerName", "customerAddress", "paymentMethod", "totalAmount", "createdAt"]
    },
    "Product": {
      "title": "Clothing Product",
      "description": "A premium clothing apparel offered on KHALAB.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "originalPrice": { "type": "number" },
        "image": { "type": "string" },
        "videoUrl": { "type": "string" },
        "sizes": { "type": "array" },
        "stock": { "type": "number" },
        "category": { "type": "string" },
        "featured": { "type": "boolean" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "title", "price", "image", "category"]
    },
    "SiteConfig": {
      "title": "Site Configuration",
      "description": "Dynamic custom configurations, themes, brand tags, templates and coordinates for KHALAB portal customization.",
      "type": "object",
      "properties": {
        "brandName": { "type": "string" },
        "tagline": { "type": "string" },
        "address": { "type": "string" },
        "mobile": { "type": "string" },
        "instagramPage": { "type": "string" },
        "facebookPage": { "type": "string" },
        "selectedTemplate": { "type": "string" },
        "themePrimary": { "type": "string" },
        "themeAccent": { "type": "string" },
        "heroTitle": { "type": "string" },
        "heroSubtitle": { "type": "string" },
        "heroImage": { "type": "string" }
      }
    }
  },
  "firestore": {
    "users": {
      "schema": "User",
      "description": "Registered customer accounts keyed by phone number."
    },
    "orders": {
      "schema": "Order",
      "description": "Purchased orders placed by customers, indexed by Order ID."
    },
    "config": {
      "schema": "SiteConfig",
      "description": "System-wide brand coordinates, templates and colors."
    },
    "products": {
      "schema": "Product",
      "description": "Active catalog items backed up on Firestore."
    },
    "catalogs": {
      "schema": "object",
      "description": "Product categories slug mapping."
    },
    "promos": {
      "schema": "object",
      "description": "Coupons and campaign discount specs."
    },
    "fakeCustomers": {
      "schema": "object",
      "description": "Blacklist records preventing fraud."
    },
    "reviews": {
      "schema": "object",
      "description": "Product feedback ratings and descriptions."
    }
  }
}
